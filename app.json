{
  "expo": {
    "name": "CMP",
    "slug": "slp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#152A24",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.futurecx.slpmobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow CMP to choose a profile photo from your library.",
        "NSCameraUsageDescription": "Allow CMP to take a profile photo."
      }
    },
    "android": {
      "package": "com.futurecx.slpmobile",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#152A24"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CMP to choose a profile photo from your library."
        }
      ]
    ]
  }
}
