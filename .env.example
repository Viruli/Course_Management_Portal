# Copy this file to .env and fill in your local values.
# .env is gitignored — never commit real values.

# Backend API base URL (no trailing slash)
# Production: https://cms.api.bethelnet.au/api/v1
# Local dev:  http://<your-machine-ip>:3000/api/v1
EXPO_PUBLIC_API_BASE_URL=https://cms.api.bethelnet.au/api/v1

# Firebase project config (obtain from Firebase Console or backend team)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
